  {
    "description": "Mandate activity summary by scheme — reveals which direct debit schemes are most actively used",
    "sql": "-- Mandate count and associated payment metrics grouped by scheme\nSELECT\n  m.scheme,\n  COUNT(DISTINCT m.id) AS total_mandates,\n  COUNT(p.id) AS total_payments,\n  SUM(p.amount) AS total_revenue,\n  AVG(p.amount) AS avg_payment_amount,\n  COUNT(p.id) / COUNT(DISTINCT m.id) AS avg_payments_per_mandate\nFROM mandates m\nLEFT JOIN payments p ON p.mandate_id = m.id\nGROUP BY m.scheme\nORDER BY total_mandates DESC",
