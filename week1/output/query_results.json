  {
    "description": "New organisations and mandates onboarded per quarter — tracks growth in platform adoption over time",
    "sql": "-- Quarterly onboarding trend: new organisations and mandates created\nSELECT\n  CONCAT(YEAR(o.created_at), '-Q', QUARTER(o.created_at)) AS quarter,\n  COUNT(DISTINCT o.id) AS new_organisations,\n  COUNT(DISTINCT m.id) AS new_mandates\nFROM organisations o\nLEFT JOIN mandates m\n  ON m.organisation_id = o.id\n  AND YEAR(m.created_at) = YEAR(o.created_at)\n  AND QUARTER(m.created_at) = QUARTER(o.created_at)\nGROUP BY CONCAT(YEAR(o.created_at), '-Q', QUARTER(o.created_at))\nORDER BY quarter ASC",
    "rows": [
