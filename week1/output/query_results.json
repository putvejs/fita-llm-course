  {
    "description": "Average days between payment creation and charge date by vertical — measures collection lag across industry sectors",
    "sql": "-- Average lead time (days) between payment creation and charge date per vertical\nSELECT\n  o.parent_vertical,\n  COUNT(p.id) AS total_payments,\n  AVG(DATEDIFF(p.charge_date, p.created_at)) AS avg_days_to_charge,\n  MIN(DATEDIFF(p.charge_date, p.created_at)) AS min_days_to_charge,\n  MAX(DATEDIFF(p.charge_date, p.created_at)) AS max_days_to_charge\nFROM payments p\nJOIN mandates m ON p.mandate_id = m.id\nJOIN organisations o ON m.organisation_id = o.id\nWHERE p.charge_date IS NOT NULL\nGROUP BY o.parent_vertical\nORDER BY avg_days_to_charge DESC",
